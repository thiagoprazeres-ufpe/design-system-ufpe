{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "RU-only design tokens for the Restaurante Universitario product surface. UFPE institutional signatures, seals and color rules are intentionally excluded.",
  "ru": {
    "$description": "Portable source tokens for Figma, Penpot and the WordPress theme.",
    "color": {
      "$type": "color",
      "brand": {
        "amarelo": {
          "$value": "#EEAB1E",
          "$description": "Amarelo Ovo. Primary RU energy color."
        },
        "amareloClaro": {
          "$value": "#E9CB83",
          "$description": "Light tint for Amarelo Ovo."
        },
        "verdeEscuro": {
          "$value": "#5F9336",
          "$description": "Deep Verde Alface."
        },
        "verde": {
          "$value": "#87C75F",
          "$description": "Verde Alface. Health, nature and vitality."
        },
        "verdeClaro": {
          "$value": "#BDE486",
          "$description": "Light tint for Verde Alface."
        },
        "azulEscuro": {
          "$value": "#50A2C6",
          "$description": "Deep Azul Frescor."
        },
        "azul": {
          "$value": "#66C6F1",
          "$description": "Azul Frescor. Freshness, hygiene and calm."
        },
        "azulClaro": {
          "$value": "#B1E5EE",
          "$description": "Light tint for Azul Frescor."
        },
        "vermelhoEscuro": {
          "$value": "#9F1929",
          "$description": "Deep Vermelho Melancia."
        },
        "vermelho": {
          "$value": "#E33D5D",
          "$description": "Vermelho Melancia. Appetite, warmth and attention."
        },
        "vermelhoClaro": {
          "$value": "#F47293",
          "$description": "Light tint for Vermelho Melancia."
        },
        "cinzaEscuro": {
          "$value": "#344348",
          "$description": "Deep Cinza Panela for neutral UI and text."
        },
        "cinza": {
          "$value": "#5F6F76",
          "$description": "Cinza Panela."
        },
        "cinzaClaro": {
          "$value": "#B1CACE",
          "$description": "Light tint for Cinza Panela."
        },
        "laranja": {
          "$value": "#F46E21",
          "$description": "Supporting RU mosaic orange. Use as an asset/support accent, not as the product primary color."
        }
      },
      "surface": {
        "base": {
          "$value": "#FFFDF8",
          "$description": "Warm page background."
        },
        "raised": {
          "$value": "#FFFFFF",
          "$description": "Raised panels, cards and form surfaces."
        },
        "muted": {
          "$value": "#F5F0E8",
          "$description": "Subtle neutral background."
        },
        "sunken": {
          "$value": "#EBE3D5",
          "$description": "Inset/table/background contrast."
        }
      },
      "text": {
        "default": {
          "$value": "#1C1814",
          "$description": "Default body text."
        },
        "muted": {
          "$value": "#7A6E60",
          "$description": "Secondary copy and metadata."
        },
        "inverse": {
          "$value": "#FFFFFF",
          "$description": "Text over dark or saturated fills."
        }
      },
      "border": {
        "subtle": {
          "$value": "#DDD5C4",
          "$description": "Default low-contrast border."
        },
        "strong": {
          "$value": "#B1CACE",
          "$description": "Higher-contrast neutral divider."
        }
      },
      "semantic": {
        "primary": {
          "$value": "#EEAB1E",
          "$description": "Primary action and main highlight."
        },
        "primaryContent": {
          "$value": "#1A0E00"
        },
        "secondary": {
          "$value": "#87C75F"
        },
        "secondaryContent": {
          "$value": "#0D1A00"
        },
        "accent": {
          "$value": "#E33D5D"
        },
        "accentContent": {
          "$value": "#FFFFFF"
        },
        "neutral": {
          "$value": "#344348"
        },
        "neutralContent": {
          "$value": "#E8F0F3"
        },
        "success": {
          "$value": "#5F9336"
        },
        "warning": {
          "$value": "#EEAB1E"
        },
        "error": {
          "$value": "#9F1929"
        },
        "info": {
          "$value": "#50A2C6"
        }
      },
      "day": {
        "segunda": {
          "$value": "#EEAB1E"
        },
        "terca": {
          "$value": "#E33D5D"
        },
        "quarta": {
          "$value": "#66C6F1"
        },
        "quinta": {
          "$value": "#87C75F"
        },
        "sexta": {
          "$value": "#9F1929"
        },
        "sabado": {
          "$value": "#5F6F76"
        },
        "domingo": {
          "$value": "#344348"
        }
      }
    },
    "font": {
      "family": {
        "$type": "fontFamily",
        "ui": {
          "$value": "Geist Variable, Geist, ui-sans-serif, system-ui, sans-serif",
          "$description": "Digital product font used by the current theme."
        },
        "legacyArtwork": {
          "$value": "Trebuchet MS, Arial, sans-serif",
          "$description": "Manual reference only for legacy RU artwork. Do not use this token to import UFPE institutional identity."
        }
      },
      "weight": {
        "$type": "fontWeight",
        "regular": {
          "$value": 400
        },
        "medium": {
          "$value": 500
        },
        "semibold": {
          "$value": 600
        },
        "bold": {
          "$value": 700
        }
      },
      "size": {
        "$type": "dimension",
        "xs": {
          "$value": "12px"
        },
        "sm": {
          "$value": "14px"
        },
        "md": {
          "$value": "16px"
        },
        "lg": {
          "$value": "18px"
        },
        "xl": {
          "$value": "20px"
        },
        "2xl": {
          "$value": "24px"
        },
        "3xl": {
          "$value": "30px"
        },
        "4xl": {
          "$value": "36px"
        },
        "5xl": {
          "$value": "48px"
        }
      },
      "lineHeight": {
        "$type": "number",
        "tight": {
          "$value": 1.15
        },
        "snug": {
          "$value": 1.25
        },
        "normal": {
          "$value": 1.5
        },
        "relaxed": {
          "$value": 1.7
        }
      }
    },
    "space": {
      "$type": "dimension",
      "0": {
        "$value": "0px"
      },
      "1": {
        "$value": "4px"
      },
      "2": {
        "$value": "8px"
      },
      "3": {
        "$value": "12px"
      },
      "4": {
        "$value": "16px"
      },
      "5": {
        "$value": "20px"
      },
      "6": {
        "$value": "24px"
      },
      "8": {
        "$value": "32px"
      },
      "10": {
        "$value": "40px"
      },
      "12": {
        "$value": "48px"
      },
      "16": {
        "$value": "64px"
      },
      "20": {
        "$value": "80px"
      }
    },
    "radius": {
      "$type": "dimension",
      "none": {
        "$value": "0px"
      },
      "sm": {
        "$value": "4px"
      },
      "md": {
        "$value": "6px"
      },
      "lg": {
        "$value": "8px"
      },
      "xl": {
        "$value": "16px"
      },
      "pill": {
        "$value": "999px"
      }
    },
    "layout": {
      "contentMaxWidth": {
        "$type": "dimension",
        "$value": "1120px",
        "$description": "Main public content measure used by the theme."
      },
      "pageGutter": {
        "$type": "dimension",
        "$value": "24px"
      }
    },
    "shadow": {
      "$type": "shadow",
      "sm": {
        "$value": "0 1px 2px rgba(52, 67, 72, 0.10)"
      },
      "md": {
        "$value": "0 10px 30px rgba(52, 67, 72, 0.12)"
      }
    },
    "motion": {
      "duration": {
        "$type": "duration",
        "fast": {
          "$value": "150ms"
        },
        "base": {
          "$value": "200ms"
        },
        "slow": {
          "$value": "700ms"
        }
      },
      "easing": {
        "$type": "cubicBezier",
        "standard": {
          "$value": [0.22, 1, 0.36, 1]
        }
      }
    }
  }
}
