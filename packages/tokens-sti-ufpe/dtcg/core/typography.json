{
  "font": {
    "family": {
      "sans": {
        "$value": "Trebuchet MS, Lucida Grande, Tahoma, sans-serif",
        "$type": "fontFamily",
        "$description": "Fonte oficial UFPE — Trebuchet MS (Vincent Connare, Microsoft, 1996)"
      }
    },
    "weight": {
      "normal": { "$value": 400, "$type": "fontWeight" },
      "bold":   { "$value": 700, "$type": "fontWeight" }
    },
    "size": {
      "xs":   { "$value": "12px", "$type": "dimension" },
      "sm":   { "$value": "14px", "$type": "dimension" },
      "base": { "$value": "16px", "$type": "dimension" },
      "md":   { "$value": "18px", "$type": "dimension" },
      "lg":   { "$value": "24px", "$type": "dimension" },
      "xl":   { "$value": "32px", "$type": "dimension" },
      "2xl":  { "$value": "44px", "$type": "dimension" }
    }
  },
  "typography": {
    "body": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.normal}",
        "fontSize": "{font.size.base}",
        "lineHeight": 1.55
      },
      "$type": "typography"
    },
    "heading": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.bold}",
        "fontSize": "{font.size.xl}",
        "lineHeight": 1.2,
        "letterSpacing": "-0.01em"
      },
      "$type": "typography"
    },
    "versalete": {
      "$value": {
        "fontFamily": "{font.family.sans}",
        "fontWeight": "{font.weight.bold}",
        "fontSize": "{font.size.base}",
        "fontVariantCaps": "small-caps",
        "textTransform": "lowercase",
        "letterSpacing": "0.04em"
      },
      "$type": "typography",
      "$description": "Versalete — usado nas assinaturas institucionais"
    }
  }
}
