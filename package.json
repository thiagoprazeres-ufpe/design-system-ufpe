{
  "name": "ufpe-design-system",
  "version": "0.4.0",
  "private": true,
  "description": "UFPE Design System — Penpot é a implementação; este repo hospeda tokens (DTCG), plugin Penpot e portal de docs.",
  "license": "SEE LICENSE IN README.md",
  "packageManager": "pnpm@9.0.0",
  "scripts": {
    "build": "pnpm -r --filter './packages/*' build && pnpm --filter @ufpe/docs build",
    "dev": "pnpm --filter @ufpe/docs dev",
    "dev:plugin": "pnpm --filter @ufpe/penpot-plugin dev",
    "tokens:build": "pnpm --filter @ufpe/tokens build",
    "penpot:snapshot": "node penpot/scripts/export-snapshot.js",
    "penpot:publish": "node penpot/scripts/publish-library.js",
    "penpot:verify": "node penpot/scripts/verify-drift.js",
    "brasoes:build-svg": "bash scripts/build-svgs.sh"
  },
  "devDependencies": {
    "typescript": "^5.6.0"
  }
}
